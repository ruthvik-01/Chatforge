# ─── ChatForge Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in real values before starting.

# ── Server ──
PORT=3000
NODE_ENV=production

# ── WhatsApp Cloud API ──
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_APP_SECRET=your_app_secret_here

# ── Authorized Owner Phone Number (with country code, no + prefix) ──
OWNER_PHONE_NUMBER=1234567890

# ── NVIDIA AI API ──
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-405b-instruct

# ── Encryption ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_a_64_hex_char_key_here

# ── Workspace ──
WORKSPACE_DIR=/workspace
PROJECT_RETENTION_DAYS=7

# ── Docker Sandbox ──
DOCKER_SANDBOX_IMAGE=node:20-slim
DOCKER_CPU_LIMIT=1
DOCKER_MEMORY_LIMIT=512m
DOCKER_NETWORK_DISABLED=false

# ── Vercel ──
# Provided via credential collection, but can be set as default
VERCEL_TOKEN=

# ── Git / GitHub ──
GITHUB_TOKEN=

# ── Azure Key Vault (optional) ──
AZURE_KEY_VAULT_URL=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Azure Blob Storage (optional) ──
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=chatforge-artifacts

# ── Credential Expiration (seconds, default 1 hour) ──
CREDENTIAL_TTL_SECONDS=3600

# ── Download Links ──
# Set to your public HTTPS domain to enable clickable download links via WhatsApp
# e.g. https://your-domain.com  (no trailing slash)
PUBLIC_URL=https://your-domain.com
# How long a download link stays valid (seconds, default 1 hour)
DOWNLOAD_LINK_TTL_SECONDS=3600

# ── Logging ──
LOG_LEVEL=info
LOG_DIR=/logs
